---
import Icon from '../ui/Icon.astro';
import SectionHeading from './SectionHeading.astro';
import { siteMeta } from '../../data/site';
---
<section class="section-shell shell" id="contact">
  <SectionHeading
    title="Contact Me"
    intro="If you'd like to talk through a role, a project, or the portfolio, feel free to reach out."
    align="center"
  />
  <div class="contact-panel contact-panel-single" data-reveal>
    <div class="contact-card contact-card-primary contact-card-expanded">
      <div class="contact-main">
        <div class="contact-summary">
          <h3>
            <a class="contact-email" href={`mailto:${siteMeta.email}`}>{siteMeta.email}</a>
          </h3>
          <p>{siteMeta.location}</p>
        </div>
      </div>
      <div class="contact-side">
        <div class="contact-actions">
          <a class="button-primary" href={`mailto:${siteMeta.email}`}>
            <Icon name="mail" class="h-4 w-4" />
            <span>Send an Email</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
