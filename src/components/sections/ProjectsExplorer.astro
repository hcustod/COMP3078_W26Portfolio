---
import SectionHeading from './SectionHeading.astro';
import ProjectsExplorerClient from './ProjectsExplorerClient';
import type { PortfolioProject } from '../../data/projects';

interface Props {
  title?: string;
  intro?: string;
  projects: PortfolioProject[];
  sectionId?: string;
  compactSpacing?: boolean;
  initialCount?: number;
  detailMode?: boolean;
  hydrate?: 'visible' | 'load' | 'idle';
}

const {
  title,
  intro,
  projects,
  sectionId = 'projects',
  compactSpacing = false,
  initialCount = 6,
  detailMode = false,
  hydrate = 'visible',
} = Astro.props;
const serializedProjects = projects.map((project) => ({
  slug: project.slug,
  title: project.title,
  track: project.track,
  category: project.category,
  summary: project.summary,
  tech: project.tech,
  imageSrc: project.image.src,
  code: project.code,
  demo: project.demo,
  docker: project.docker,
  features: project.features,
}));
---
<section class:list={['section-shell', 'shell', compactSpacing && 'section-shell-compact-top']} id={sectionId}>
  {title && <SectionHeading title={title} intro={intro} />}
  {hydrate === 'load' ? (
    <ProjectsExplorerClient
      projects={serializedProjects}
      detailMode={detailMode}
      initialCount={initialCount}
      client:load
    />
  ) : hydrate === 'idle' ? (
    <ProjectsExplorerClient
      projects={serializedProjects}
      detailMode={detailMode}
      initialCount={initialCount}
      client:idle
    />
  ) : (
    <ProjectsExplorerClient
      projects={serializedProjects}
      detailMode={detailMode}
      initialCount={initialCount}
      client:visible
    />
  )}
</section>
