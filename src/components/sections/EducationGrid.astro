---
import SectionHeading from './SectionHeading.astro';
import { education } from '../../data/site';

interface Props {
  title?: string;
  intro?: string;
  sectionId?: string;
}

const {
  title = 'Academic Background',
  intro = 'Degrees, coursework, and program details gathered in one place.',
  sectionId,
} = Astro.props;
---
<section class="section-shell shell" id={sectionId}>
  <SectionHeading title={title} intro={intro} />
  <div class="card-grid">
    {education.map((item) => (
      <article class="glass-card" data-reveal>
        <p class="section-eyebrow">{item.date}</p>
        <h3>{item.school}</h3>
        <p class="muted-copy">{item.location}</p>
        <p><strong>{item.degree}</strong></p>
        <p>CGPA: {item.cgpa}</p>
        <ul class="bullet-list compact">
          {item.coursework.map((course) => <li>{course}</li>)}
        </ul>
      </article>
    ))}
  </div>
</section>
