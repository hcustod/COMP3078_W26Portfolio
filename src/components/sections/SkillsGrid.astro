---
import { Image } from 'astro:assets';
import Icon from '../ui/Icon.astro';
import { skillGroups } from '../../data/site';

interface Props {
  title?: string;
  sectionId?: string;
}

const {
  title = 'Technical Range',
  sectionId,
} = Astro.props;

const carouselId = `${sectionId ?? 'skills'}-carousel-track`;
---
<section class="section-shell shell" id={sectionId}>
  <div class="skills-carousel" data-skills-carousel>
    <div class="skills-carousel-header section-heading" data-reveal>
      <h2>{title}</h2>
      <div class="skills-carousel-controls" aria-label="Skill group carousel controls">
        <button
          class="skills-carousel-button is-prev"
          type="button"
          aria-controls={carouselId}
          aria-label="Show previous skill groups"
          data-skills-prev
        >
          <Icon name="arrow" class="h-4 w-4" />
        </button>
        <button
          class="skills-carousel-button"
          type="button"
          aria-controls={carouselId}
          aria-label="Show next skill groups"
          data-skills-next
        >
          <Icon name="arrow" class="h-4 w-4" />
        </button>
      </div>
    </div>

    <div class="skills-carousel-viewport">
      <div class="skills-carousel-track" id={carouselId} data-skills-track>
        {skillGroups.map((group) => (
          <article class="glass-card skill-group-card skill-carousel-card" data-reveal>
            <h3>{group.title}</h3>
            <div class="skill-cloud">
              {group.items.map((item) => (
                <div class="skill-pill">
                  <span class="skill-icon-box" aria-hidden="true">
                    <Image src={item.icon} alt={item.name} width={48} height={48} />
                  </span>
                  <span class="skill-label">{item.name}</span>
                </div>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
