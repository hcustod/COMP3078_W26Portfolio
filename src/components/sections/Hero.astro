---
import Icon from '../ui/Icon.astro';
import { socialLinks } from '../../data/site';

interface HeroLink {
  label: string;
  href: string;
  icon: string;
  tone?: 'accent';
  full?: boolean;
}

const heroLinks: HeroLink[] = [
  { ...socialLinks[1], tone: 'accent', full: true },
  { ...socialLinks[0] },
  { ...socialLinks[2] },
];
---
<section class="hero-shell shell" id="home">
  <div class="hero-panel" data-reveal>
    <div class="hero-main">
      <h1>Henrique Custodio</h1>
      <p class="hero-role">Developer. Cloud Engineer. Lover of <span class="hero-role-space">Space.</span></p>
      <p class="hero-copy">
        I build dependable applications with a passion for clean, scalable, and sustainable development; with a focus on practical delivery.
      </p>
    </div>

    <div class="hero-side">
      <div class="hero-social-grid" aria-label="Primary links">
        {heroLinks.map((link) => (
          <a
            class:list={[
              'icon-link',
              'hero-social-link',
              link.tone === 'accent' && 'hero-social-link-accent',
              link.full && 'hero-social-link-full',
            ]}
            href={link.href}
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noreferrer' : undefined}
          >
            <Icon name={link.icon} class="h-4 w-4" />
            <span>{link.label}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
