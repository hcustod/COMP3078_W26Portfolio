---
import { Image } from 'astro:assets';
import { experiences } from '../../data/site';

interface Props {
  sectionId?: string;
}

const { sectionId } = Astro.props;
---
<section class="section-shell shell section-shell-compact-top" id={sectionId}>
  <div class="timeline-grid professional-timeline">
    {experiences.map((entry) => (
      <article class="timeline-card professional-entry" data-reveal>
        <div class="timeline-head professional-entry-head">
          <div class="timeline-logo">
            <Image src={entry.logo} alt={entry.company} width={56} height={56} />
          </div>
          <div class="professional-entry-meta">
            <h3>{entry.company}</h3>
            <p>{entry.role}</p>
            <small>{entry.date} · {entry.location}</small>
          </div>
        </div>
        <p class="professional-entry-summary">{entry.summary}</p>
        <div class="detail-stack professional-entry-details">
          <div>
            <h4>Responsibilities</h4>
            <ul class="bullet-list compact">
              {entry.points.map((point) => <li>{point}</li>)}
            </ul>
          </div>
        </div>
        <div class="tech-row professional-entry-tools">
          {entry.tools.map((tool) => <span class="tag-chip">{tool}</span>)}
        </div>
      </article>
    ))}
  </div>
</section>
