---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ProjectsExplorer from '../components/sections/ProjectsExplorer.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import { projectArchive } from '../data/projects';

const currentPath = Astro.url.pathname;
---
<BaseLayout
  currentPath={currentPath}
  title="Academic Work | Henrique Custodio"
  description="Academic and project-focused work collected into one dedicated section."
>
  <section class="section-shell shell page-hero archive-page-hero">
    <SectionHeading
      title="Academic Work and Projects Archive"
      intro="An archive of my academic and personal projects."
    />
  </section>

  <ProjectsExplorer
    projects={projectArchive}
    sectionId="archive"
    compactSpacing={true}
    initialCount={9}
    detailMode={true}
    hydrate="load"
  />
</BaseLayout>
