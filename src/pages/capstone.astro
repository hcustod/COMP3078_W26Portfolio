---
import BaseLayout from '../components/layout/BaseLayout.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import Icon from '../components/ui/Icon.astro';
import { capstone } from '../data/capstone';

const currentPath = Astro.url.pathname;
---
<BaseLayout
  currentPath={currentPath}
  title="Capstone | Henrique Custodio"
  description="WrenchIT capstone overview with the published project documents linked directly from the page."
>
  <section class="section-shell shell page-hero capstone-page-hero">
    <SectionHeading
      title={capstone.projectTitle}
      intro={capstone.statusNote}
    />
  </section>

  <section class="section-shell shell capstone-section">
    <article class="glass-card prose-card capstone-overview-card" data-reveal>
      <h3>Project Overview</h3>
      {capstone.overview.map((paragraph) => (
        <p>{paragraph}</p>
      ))}
    </article>
  </section>

  <section class="section-shell shell capstone-section" id="documents">
    <SectionHeading
      title="Published Capstone Resources"
      intro="Open the published project packet in-browser where available, or download the source files directly from the same capstone flow."
    />
    <div class="card-grid capstone-artifact-grid">
      {capstone.artifacts.map((artifact) => (
        <article class="glass-card compact-card capstone-artifact-card" data-reveal>
          <div class="card-topline capstone-artifact-topline">
            <p class="section-eyebrow">{artifact.category}</p>
          </div>
          <div class="capstone-artifact-copy">
            <h3>{artifact.label}</h3>
            <p>{artifact.detail}</p>
          </div>
          <div class="artifact-actions capstone-artifact-actions">
            {artifact.previewable ? (
              <a class="button-secondary capstone-artifact-button" href={artifact.href} target="_blank" rel="noreferrer">
                <Icon name="external" class="h-4 w-4" />
                <span>Open in Browser</span>
              </a>
            ) : (
              <a class="button-secondary capstone-artifact-button" href={artifact.href} download>
                <Icon name="download" class="h-4 w-4" />
                <span>Download File</span>
              </a>
            )}
            {artifact.previewable && (
              <a class="button-secondary capstone-artifact-button" href={artifact.href} download>
                <Icon name="download" class="h-4 w-4" />
                <span>Download File</span>
              </a>
            )}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
