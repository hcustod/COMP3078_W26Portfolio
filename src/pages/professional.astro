---
import BaseLayout from '../components/layout/BaseLayout.astro';
import ExperienceTimeline from '../components/sections/ExperienceTimeline.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';

const currentPath = Astro.url.pathname;
---
<BaseLayout
  currentPath={currentPath}
  title="Professional Summary | Henrique Custodio"
  description="Professional experience organized as a resume-style role timeline."
>
  <section class="section-shell shell page-hero professional-page-hero">
    <SectionHeading
      title="Professional Experience"
      intro="My professional working experience along with brief descriptions of responsibilities."
    />
  </section>

  <ExperienceTimeline />
</BaseLayout>
