---
import BaseLayout from '../components/layout/BaseLayout.astro';
import EducationGrid from '../components/sections/EducationGrid.astro';
import CertificationsGrid from '../components/sections/CertificationsGrid.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';

const currentPath = Astro.url.pathname;
---
<BaseLayout
  currentPath={currentPath}
  title="Academic Credentials | Henrique Custodio"
  description="Degrees, certifications, academic highlights, and program history."
>
  <section class="section-shell shell page-hero">
    <SectionHeading
      title="Degrees, coursework, and certifications"
      intro="A direct academic-only view of the same background material that is integrated into the About page."
    />
    <div class="toolbar-actions" data-reveal>
      <a class="button-secondary" href="/about/#academic">Open integrated About page</a>
    </div>
  </section>

  <EducationGrid
    title="Education history and academic context"
    intro="Program history, coursework, and highlights kept in one academic-only section."
  />

  <CertificationsGrid
    title="Industry certifications"
    intro="Technical certifications earned alongside academic study."
  />
</BaseLayout>
