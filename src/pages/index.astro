---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ProjectsExplorer from '../components/sections/ProjectsExplorer.astro';
import ContactPanel from '../components/sections/ContactPanel.astro';
import { featuredProjects } from '../data/projects';

const currentPath = Astro.url.pathname;
---
<BaseLayout currentPath={currentPath}>
  <Hero />
  <ProjectsExplorer
    title="Featured Projects"
    intro="Projects of different kinds which I have created over the years."
    projects={featuredProjects}
    sectionId="projects"
    initialCount={6}
    hydrate="visible"
  />
  <ContactPanel />
</BaseLayout>
