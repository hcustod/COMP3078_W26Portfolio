---
import BaseLayout from '../components/layout/BaseLayout.astro';
import EducationGrid from '../components/sections/EducationGrid.astro';
import CertificationsGrid from '../components/sections/CertificationsGrid.astro';
import SkillsGrid from '../components/sections/SkillsGrid.astro';
import SectionHeading from '../components/sections/SectionHeading.astro';
import DocumentList from '../components/sections/DocumentList.astro';
import Icon from '../components/ui/Icon.astro';
import { documents, siteMeta } from '../data/site';

const currentPath = Astro.url.pathname;
const anchors = [
  { id: 'personal', label: 'Personal' },
  { id: 'academic', label: 'Academic' },
  { id: 'credentials', label: 'Certifications' },
  { id: 'skills', label: 'Skills' },
  { id: 'documents', label: 'Documents' },
];
---
<BaseLayout
  currentPath={currentPath}
  title="About | Henrique Custodio"
  description="Bio, academic background, certifications, and supporting documents."
>
  <section class="section-shell shell page-hero" id="personal">
    <div class="anchor-nav about-anchor-nav" data-reveal>
      {anchors.map((anchor) => (
        <a class="filter-chip" href={`#${anchor.id}`}>{anchor.label}</a>
      ))}
    </div>
    <SectionHeading
      title="Bio"
      intro="Personal background, career direction, academic context, certifications, skills, and core documents."
    />
    <article class="glass-card prose-card about-bio-card" data-reveal>
      <h3>Bio</h3>
      <p>
        Henrique Custodio is a developer with hands-on experience across cloud engineering, Linux systems administration, database operations, and full-stack web delivery. His recent work has included containerizing legacy applications, migrating databases, improving deployment workflows, and supporting production systems where reliability matters.
      </p>
      <p>
        Alongside professional work, he uses academic and personal projects to keep building depth in application development, automation, and infrastructure. The portfolio is designed to keep that work readable: clear project context, practical outcomes, and enough technical detail to show how things were built.
      </p>
      <div class="about-philosophy">
        <h3>Career Philosophy</h3>
        <p>
          I aim to build software that is clear, reliable, and practical to operate. The best systems solve real problems, stay maintainable over time, and leave the next person with a cleaner path forward.
        </p>
      </div>
      <div class="stack-actions">
        <a class="button-primary" href={siteMeta.resumePath} target="_blank" rel="noreferrer">
          <Icon name="download" class="h-4 w-4" />
          <span>Open Resume PDF</span>
        </a>
        <a class="button-secondary" href={siteMeta.coverLetterPath} target="_blank" rel="noreferrer">
          <Icon name="document" class="h-4 w-4" />
          <span>Open Cover Letter PDF</span>
        </a>
      </div>
    </article>
  </section>

  <EducationGrid
    sectionId="academic"
    title="Academic Background"
    intro="Degrees, coursework, and program details kept together so background material is easy to scan."
  />

  <CertificationsGrid
    sectionId="credentials"
    title="Technical Certifications"
    intro="Industry credentials that complement the academic side of the portfolio."
  />

  <SkillsGrid
    sectionId="skills"
    title="Technical Range"
  />

  <DocumentList
    sectionId="documents"
    title="Core Documents"
    intro="Resume, written material, academic summary, and the capstone document hub in one place."
    items={documents}
  />
</BaseLayout>
